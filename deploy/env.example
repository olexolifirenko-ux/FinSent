# FinSent prod secrets — read by com.finsent.core.Secrets as a fallback to real env vars.
# Format: KEY=value (no quotes needed). Empty value => that feature stays OFF.
# This file is PROD-ONLY. Keep it 0600. Never commit it.
#
# SAFETY: with broker keys blank, FSTrader falls back to paper and stays flat.
# Filling WHITEBIT_* below is what enables real money — do that deliberately,
# and only after the wbstop_probe.pl venue check.

# --- Claude (analysis). Blank => analyser cannot call Claude (HTTP 401). ---
ANTHROPIC_API_KEY=

# --- News / data sources. Blank => that source is skipped. ---
NEWSAPI_KEY=
POLYGON_KEY=
CRYPTOPANIC_KEY=
BLS_API_KEY=
GETXAPI_KEY=

# --- Alerts ---
TELEGRAM_TOKEN=
SMTP_PASSWORD=

# --- LIVE BROKER (WhiteBIT). Blank => paper mode. Fill ONLY to go live. ---
WHITEBIT_API_KEY=
WHITEBIT_API_SECRET=
