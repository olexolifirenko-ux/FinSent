# --- Gradle / build output ---
/.gradle/
/build/
/JavaClasses.sun/
/JavaClasses/

# --- Assembled runtime classpath (regenerated by `gradlew deployRelease`) ---
/release/common/lib/

# --- Single-instance lock files (EXCLUSIVE_MODE) ---
/release/run/

# --- linux64 JRE: populated on a Linux deploy, not committed.
#     (win64/jre IS committed so Windows clones are turnkey.) ---
/release/common/linux64/jre/

# --- Runtime-generated logs (keep the directory, ignore contents) ---
/release/logs/*
!/release/logs/.gitkeep

# --- Secrets (read by com.finsent.core.Secrets as a fallback to real env vars) ---
/release/.env
.env
.env.*

# --- IDE / OS ---
/.idea/
.vscode/
*.iml
*.swp
*.swo
*~
Thumbs.db
ehthumbs.db
.DS_Store

# Note: lib/*.jar (vendored dependencies) and gradle/wrapper/gradle-wrapper.jar
# are intentionally committed so the project builds offline after a clean clone.
