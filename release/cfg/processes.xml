<?xml version="1.0" encoding="UTF-8"?>
<!--
  FinSent backend bootstrap configuration.

  Loaded by AbstractAppInitializer (the -bootstrapDataFile launcher argument)
  and handed to GlobalSystem.initialize(). GlobalSystem selects the top-level
  element matching the process -type / -name (see GlobalSystem.getProcessData)
  and then reads the <GlobalSystem> child of that section (see
  GlobalSystem.registerOrRunInitializers).

  Declare one top-level element per process type. Add more sections here as
  further process types are introduced.
-->
<Bootstrap>
    <!-- Launched by release/bin/FSSatellite.pl (-type FSSatellite). This is the default,
         *unnamed* section: GlobalSystem.getProcessData selects it for an FSSatellite process
         whether or not a -name is given (a -name with no matching named section falls back here). -->
    <FSSatellite>
        <GlobalSystem
            configDataResource="cfg/system.xml"
            logFacilityName="FSSatelliteLogFacility"
        >
            <!--
              Process-specific custom initializers are declared here, e.g.:
              <InitializerList>
                  <Initializer customInitializerClassName="com.finsent.<Initializer>"/>
              </InitializerList>
            -->
        </GlobalSystem>

        <!--
          Pipeline configuration (ported from the Python sentiment_config.json), split by
          ownership into two sibling sections that com.finsent.core.Config reads from this
          bootstrap node. Scalars are attributes; source/feed lists and macro thresholds are
          child elements. Secret-bearing attributes use the ENV:VAR convention, resolved at
          read time by com.finsent.core.Secrets. Duration specs (10m / 12h / 30m / 1h) carry
          their unit in the value; numeric measurements use unit-suffixed names.
        -->

        <!--
          What the collector owns: data cadence & shape. The three params marked [shared]
          (analysisNewsWindow / ohlcImpactWindow / optionsEnabled) are read by the analyser
          via the collector at runtime, so they live here as the single source of truth.
        -->
        <FSCollector
            dataDir="data"
            analysisNewsWindow="10m"
            ohlcImpactWindow="30m"
            macroEnabled="false"
            optionsEnabled="true"
            fundingEnabled="true"
            econEnabled="false"
            ohlcBarSize="1m"
            articleMaxAge="72h"
            urgentPollInSec="30"
            recoveryLookbackInDays="3"
            yahooChartBaseUrl="https://query1.finance.yahoo.com/v8/finance/chart"
            deribitBaseUrl="https://www.deribit.com/api/v2"
            binanceFuturesBaseUrl="https://fapi.binance.com/fapi/v1"
            blsApiKey="ENV:BLS_API_KEY"
            getxapiKey="ENV:GETXAPI_KEY"
            getxapiMaxPages="5"
        >
            <Sources>
                <Source name="newsapi"     apiKey="ENV:NEWSAPI_KEY"/>
                <Source name="polygon"     apiKey="ENV:POLYGON_KEY"/>
                <Source name="cryptopanic" apiKey="ENV:CRYPTOPANIC_KEY"/>
                <Source name="rss"/>
            </Sources>

            <!-- Primary monetary/regulatory sources. The crypto-native outlets (CoinDesk, TheBlock,
                 BloombergCrypto) were promoted to UrgentSources for faster pickup; the lagged general-macro
                 wires (Bloomberg Markets/Economics, CNBC) and low-crypto-yield geopolitical feeds (ArabNews,
                 TimesOfIsrael) were pruned (monitor reframe). -->
            <RssFeeds>
                <Feed name="ECB_Press"          url="https://www.ecb.europa.eu/rss/press.html"/>
                <Feed name="BoJ"                url="https://www.boj.or.jp/en/rss/whatsnew.xml"/>
                <Feed name="BoE"                url="https://www.bankofengland.co.uk/rss/news"/>
                <Feed name="SEC_Press"          url="https://www.sec.gov/news/pressreleases.rss"/>
            </RssFeeds>

            <!-- Fast official/primary sources, plus the crypto-native outlets (CoinDesk, TheBlock,
                 BloombergCrypto) promoted from the regular RSS lane for faster pickup. The geopolitical
                 wires (AlJazeera, IranIntl) were pruned: a low-crypto-yield bearish firehose the analyser
                 repeatedly mis-called. -->
            <UrgentSources>
                <Source name="TruthSocial_Trump" url="https://www.trumpstruth.org/feed"/>
                <Source name="FedReserve"        url="https://www.federalreserve.gov/feeds/press_all.xml"/>
                <Source name="WhiteHouse"        url="https://www.whitehouse.gov/presidential-actions/feed/"/>
                <Source name="CoinDesk"          url="https://www.coindesk.com/arc/outboundfeeds/rss/"/>
                <Source name="TheBlock"          url="https://www.theblock.co/rss.xml"/>
                <Source name="BloombergCrypto"   url="https://feeds.bloomberg.com/crypto/news.rss"/>
            </UrgentSources>

            <!-- Fast X (Twitter) amplifier accounts, fetched as one merged from:a OR from:b query on the
                 urgent lane (GetXAPI advanced_search). Curate by reliability, not reach. Requires
                 GETXAPI_KEY in release/.env; without it the source is skipped. Fast wires first, then
                 principals. NOTE: @realDonaldTrump is intentionally NOT here; he posts on Truth Social,
                 not X (his X mirror lags weeks and missed the Iran-deal post), so the trumpstruth.org
                 RSS in UrgentSources is the faster, primary Trump source. -->
            <XAccounts>
                <Account handle="DeItaone"/>
                <Account handle="FirstSquawk"/>
                <Account handle="unusual_whales"/>
                <Account handle="WatcherGuru"/>
                <Account handle="federalreserve"/>
                <Account handle="SECGov"/>
                <Account handle="NickTimiraos"/>     <!-- WSJ Fed whisperer; monetary-surprise signal -->
                <Account handle="SecScottBessent"/>  <!-- US Treasury Secretary; debt/dollar/sanctions/deals -->
            </XAccounts>

            <!-- Situational principals: follow temporarily while a specific situation is developing,
                 PRUNE once it resolves. Merged with XAccounts into one query; total (core + situational)
                 must stay <= 25 handles or GetXAPI advanced_search silently returns nothing.
                 Current set (2026-06): the Iran-US peace deal / Middle East / oil-price situation;
                 these move BTC via the oil to risk-sentiment channel. Remove after the deal is signed
                 and priced in. -->
            <XSituationalAccounts>
                <!--Account handle="CMShehbaz"/-->   <!-- Pakistan PM; broke the deal announcement. But - commented since he was relevant for exactly one event (Iran mediation) -->
                <Account handle="SecRubio"/>         <!-- US Secretary of State; deal/sanctions -->
                <Account handle="Netanyahu"/>        <!-- Israel; Iran/Israel axis -->
                <Account handle="TankerTrackers"/>   <!-- Hormuz/oil-supply OSINT via AIS satellite data; leads wires on tanker transits/blockades. PRUNE once the oil-supply-shock situation resolves -->
                <Account handle="AJEnglish"/>        <!-- Cautious trial: fastest English source for ME military escalation (geographic proximity). This is the LOW-VOLUME X handle, NOT the AlJazeera RSS firehose that was pruned for mis-calls. Watch screener/deep noise; PRUNE once ME escalation resolves -->
            </XSituationalAccounts>
        </FSCollector>

        <!-- What the analyser owns: interpretation (Claude models/screening) plus, in the <Notifications>
             child, the notify gate + delivery channels. -->
        <FSAnalyser
            anthropicApiKey="ENV:ANTHROPIC_API_KEY"
            claudeDeepAnalModel="claude-sonnet-4-6"
            claudeDeepEffort="medium"
            claudeScreenerModel="claude-haiku-4-5-20251001"
            anthropicMessagesUrl="https://api.anthropic.com/v1/messages"
            screenerThreshold="2"
            deepDedupLookback="24h"
            promptsDir="prompts"
        >
            <!-- Delivery channels (Telegram + email/SMTP) and the notify gate (notifyMinImpactTier =
                 minimum materiality to alert; newsAgeToNotify = a resonant article must be this fresh). -->
            <Notifications
                notifyMinImpactTier="high"
                newsAgeToNotify="1h"
                telegramToken="ENV:TELEGRAM_TOKEN"
                telegramChatId="645133217"
                telegramApiBaseUrl="https://api.telegram.org"
                emailTo="olex.olifirenko@gmail.com"
                smtpHost="smtp.gmail.com"
                smtpPort="587"
                smtpUser="olex.olifirenko@gmail.com"
                smtpPassword="ENV:SMTP_PASSWORD"
            />
        </FSAnalyser>

        <!-- What the trader owns: long/short BTC execution off TWO signal lanes, each with its own entry rules +
             size + initial stop in a sub-element: <NewsLane> off the analyser's AnalysisReady signals,
             <FastMoveLane> off the mechanical FastMove fires. One net position at a time across BOTH lanes.
             Starts paused unless -DrunTrader=true; toggle live with `trade`. The SHARED execution + exit-
             management + risk settings stay as <FSTrader> attributes:
               broker                     - "paper" (simulated fills, no real orders) or "whitebit" (live WhiteBIT futures).
               entryMaxPriceDivergencePct - skip an entry if the live price has moved more than this % from the signal's
                                            analysis-time anchor (the market repriced since the verdict). 0 disables.
               trailInPct                 - trailing-stop distance behind the best price, in %.
               profitGraceInMin           - close if not in profit by this many minutes (the "is the thesis working?"
                                            time stop). 0 disables.
               maxHoldInHours             - max holding time before closing regardless of price (a chop backstop).
               pricePollInSec             - how often the open position is re-evaluated (trail/exit) and reconciled
                                            against the venue.
               feeRatePct                 - taker fee per side, as a % of traded notional, charged on BOTH entry and exit;
                                            all reported P&L is net of it. SET THIS TO YOUR REAL WhiteBIT fee tier
                                            (observed ~0.1% on this account). Used for live (modeled) and paper P&L.
               slippageInPct              - PAPER-ONLY per-side slippage the paper broker applies to fills (spread+impact).
                                            IGNORED when broker=whitebit (live fills already carry real slippage).
               maxDailyLossInUsd          - daily realized-loss kill-switch: once the day's NET realized P&L is <= -this,
                                            halt new opens for the rest of the UTC day (open positions still close). 0 = off.
               maxTradesPerDay            - max round trips per UTC day before halting new opens (whipsaw breaker). 0 = off.
               venueStop                  - when live, attach a venue-resting protective stop (a standalone trigger-market
                                            order at the initial stop) so the position keeps a stop even if this process
                                            dies; a deliberate close cancels it first. Paper ignores it (no resting orders).
               whitebitApiKey/Secret      - WhiteBIT private-API credentials (resolved from release/.env via ENV:).
               whitebitBaseUrl/Market     - WhiteBIT API base URL and the collateral (futures) market to trade.
             broker=paper simulates fills (no real orders); broker=whitebit places live WhiteBIT futures orders. -->
        <FSTrader
            broker="whitebit"
            entryMaxPriceDivergencePct="1.0"
            trailInPct="1.0"
            profitGraceInMin="30"
            maxHoldInHours="24"
            pricePollInSec="20"
            feeRatePct="0.1"
            slippageInPct="0.02"
            maxDailyLossInUsd="0.0"
            maxTradesPerDay="0"
            venueStop="true"
            whitebitApiKey="ENV:WHITEBIT_API_KEY"
            whitebitApiSecret="ENV:WHITEBIT_API_SECRET"
            whitebitBaseUrl="https://whitebit.com"
            whitebitMarket="BTC_USDT"
        >
            <!-- News lane: opens long on bullish / short on bearish at entryImpactTier or higher, and only on
                 a FRESH catalyst (the newest resonant article no older than entryMaxNewsAgeInMin, so it never
                 opens on a stale re-analysis/backfill/late-article call; 0 disables that gate). reversalExit=true
                 closes an open news position when a fresh opposite-direction call of the same tier arrives - the
                 catalyst it opened on has been contradicted (closes only, never flips). Own size + stop. -->
            <NewsLane
                entryImpactTier="high"
                entryMaxNewsAgeInMin="5"
                reversalExit="true"
                notionalInUsd="300.0"
                leverage="5.0"
                stopLossInPct="0.3"
            />
            <!-- FastMove (momentum) lane: trade=false is ALERT-ONLY (publish/log, never open); the safe
                 default while tuning. minConviction=full opens only on full-conviction (OI-building) fires;
                 reduced fires still publish/log as telemetry but do not trade (the backtest showed reduced
                 net-loses). reversalExit=true closes the position on a confirmed opposite fire. Own (smaller)
                 size + (wider) initial stop, since a momentum entry fires mid-move and whipsaws on a tight stop. -->
            <FastMoveLane
                trade="false"
                minConviction="full"
                reversalExit="true"
                reentryCooldownInMin="30"
                notionalInUsd="150.0"
                leverage="3.0"
                stopLossInPct="1.0"
            />
        </FSTrader>
        <!-- WhiteBIT keys above back the `trade wbcheck`/`trade wborder` commands and, when broker=whitebit,
             the auto-trader's live orders. Put the real values in release/.env as WHITEBIT_API_KEY /
             WHITEBIT_API_SECRET (gitignored). For live trading set broker=whitebit and each lane's leverage
             to match the leverage configured in the WhiteBIT UI for this market. -->

        <!-- The mechanical FastMove price-tape trigger: a separate collector-side daemon that samples the live
             BTC price and fires a directional momentum signal when the tape moves far+cleanly on any <Window>,
             graded by a funding/OI structural gate (OI building = full conviction = real trend; OI unwinding =
             skip = likely transient wick). News-independent; catches flow-led moves the news lane lags. This
             element holds ONLY the DETECTION settings; the momentum lane's TRADING settings live in
             <FSTrader><FastMoveLane>. The poller thread always runs; it starts paused unless -DrunFastMove
             (default off, the safe default, like the analyser/trader), and is toggled live via
             `fastmove on|off|status`. Each <Window>
             carries its own span + the endpoint move (%) that fires it + the regression r2 floor that rejects
             choppy drift; a short span catches flash crashes, a long one catches slow grinds; the once-per-move
             latch means extra windows make detection earlier, not more frequent. -->
        <FSFastMove
            pollInSec="20"
            cooldownInMin="30"
            oiBuildingPct="0.5"
            oiLookbackInMin="40"
            accelRatio="1.5"
            fundingCompressionDropPct="40"
            fundingCompressionWindow="60m"
        >
            <Windows>
                <Window span="5m"  thresholdPct="0.8" r2Floor="0.45"/>   <!-- flash crash / cascade -->
                <Window span="15m" thresholdPct="1.0" r2Floor="0.55"/>   <!-- spike -->
                <Window span="30m" thresholdPct="1.5" r2Floor="0.55"/>   <!-- grind (the 06-24 unwind) -->
            </Windows>
        </FSFastMove>
    </FSSatellite>
</Bootstrap>
